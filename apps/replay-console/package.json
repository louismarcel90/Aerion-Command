{
  "name": "@aerion/replay-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@aerion/contracts": "workspace:*",
    "@aerion/replay-engine": "workspace:*",
    "@aerion/renderer-ascii": "workspace:*"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  }
}